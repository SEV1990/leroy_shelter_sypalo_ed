# Copy to .env and fill in. Never commit the real .env.

# Port the server listens on
PORT=3000

# Admin panel password (used at POST /api/admin/login)
ADMIN_PASSWORD=change-me-please

# Secret used to sign admin JWTs. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Optional: where the SQLite file lives (defaults to backend/data.sqlite)
# DB_PATH=/var/data/shelter.sqlite

# Optional: Telegram notifications for new contact / evacuation requests.
# 1. Create a bot via @BotFather -> get the token.
# 2. Add the bot to your chat/channel, then find the chat id
#    (e.g. message @userinfobot, or use getUpdates).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
